# Gitignore for Inkstream project

# Node.js
node_modules/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-store/

# Next.js
.next/
out/

# Turborepo
.turbo/

# TypeScript
*.tsbuildinfo

# pnpm
pnpm-debug.log*

# Editor directories and files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS-specific
.DS_Store
Thumbs.db

# dotenv files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build artifacts
dist/
# Compiled JS/d.ts artifacts in src/ (generated by tsc, should not be committed)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
prompts/
.copilot
# Force single versions of prosemirror packages
public-hoist-pattern[]=*prosemirror*

# Resolution overrides
resolution-mode=highest

# Private registry for @inkstream pro packages.
# Customers: set INKSTREAM_NPM_TOKEN in your environment (never commit the token).
# @inkstream:registry=https://npm.pkg.github.com
# //npm.pkg.github.com/:_authToken=${INKSTREAM_NPM_TOKEN}

# Force single versions of prosemirror packages
public-hoist-pattern[]=*prosemirror*

# Resolution overrides
resolution-mode=highest

# Private registry for @inkstream-dev pro packages.
# Set GITHUB_TOKEN in your environment (never commit the token value directly).
@inkstream-dev:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}

# Legacy commented entry kept for reference (old @inkstream scope):
# @inkstream:registry=https://npm.pkg.github.com
